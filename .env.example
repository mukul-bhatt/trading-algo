# ─────────────────────────────────────────────────────────────────────────────
# Zerodha Kite Connect – Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# STEP 1: Copy this file to ".env"  →  cp .env.example .env
# STEP 2: Fill in your real values below
# STEP 3: Never commit the ".env" file to git (it is already in .gitignore)
#
# WHERE TO GET THESE VALUES:
#   - Log in to https://developers.kite.trade/
#   - Create or open your app
#   - API Key and API Secret are shown on the app dashboard
#
# ─────────────────────────────────────────────────────────────────────────────

# Your Kite Connect API key (public identifier for your app)
KITE_API_KEY=your_api_key_here

# Your Kite Connect API secret (keep this absolutely private)
KITE_API_SECRET=your_api_secret_here

# ─── DRY RUN / PAPER TRADING ─────────────────────────────────────────────────
# When set to "true", the bot will log what it WOULD do but NOT actually
# place any real orders. Always test with DRY_RUN=true first!
# DRY_RUN=true

# ─── LOGGING ─────────────────────────────────────────────────────────────────
# Log level: "error" | "warn" | "info" | "debug"
# "info"  → normal operation messages
# "debug" → very verbose, useful while learning / troubleshooting
LOG_LEVEL=info

# ─── HOLDINGS SPIKE MONITOR ───────────────────────────────────────────────────
# Detects operator exit via volume + order-book depth spikes on your holdings.
# BOTH signals must fire simultaneously to trigger an alert or auto-sell.
#
# AUTO_SELL_ON_SPIKE:
#   false = only log a loud warning (safe for testing with small amounts)
#   true  = automatically place a CNC SELL MARKET order when spike is detected
AUTO_SELL_ON_SPIKE=false

# How many past trading days to use for the volume baseline (median).
VOLUME_LOOKBACK_DAYS=7

# Alert if today's actual volume (time-adjusted) is this many times the expected.
VOLUME_SPIKE_MULTIPLIER=3.0

# Alert if (sell_quantity / buy_quantity) in the order book is >= this ratio.
DEPTH_RATIO_ALERT_THRESHOLD=0.3

# Minimum seconds between alerts for the same stock (prevents alert flooding).
SPIKE_COOLDOWN_SECONDS=60

# How often (ms) to re-fetch holdings (picks up new buys during the day).
HOLDINGS_REFRESH_MS=300000

# ─────────────────────────────────────────────────────────────────────────────
# LOWER CIRCUIT GUARD
# Automatically cancels pending BUY orders if a stock hits lower circuit.
# Use this to protect against buying into a stock after the operator exits.
# ─────────────────────────────────────────────────────────────────────────────

# Whether to auto-cancel pending BUY orders when a stock is at lower circuit.
# false = log the alert only (safe default for testing)
# true  = automatically call cancelOrder() for that stock's open BUY orders
CANCEL_ON_LOWER_CIRCUIT=true

# How often (ms) to poll for lower circuit events.
# 30000 = check every 30 seconds.
CIRCUIT_GUARD_INTERVAL_MS=30000

# ─────────────────────────────────────────────────────────────────────────────
# STOP-LOSS (holdings)
# Sells a holding if its price drops more than X% below the PREVIOUS DAY's
# closing price. For T2T stocks in upper circuit, previous close = upper circuit
# price. If the stock has fallen 3% below that, the operator has likely exited
# and the stock is no longer safe to hold.
# ─────────────────────────────────────────────────────────────────────────────

# Whether to enable the stop-loss check.
# false = calculate and log only | true = auto-sell if threshold breached
STOP_LOSS_ENABLED=true

# How many percent below the previous day's close triggers a stop-loss sell.
# 3 = sell if LTP has fallen more than 3% from yesterday's close.
STOP_LOSS_PCT=2

# ─────────────────────────────────────────────────────────────────────────────
# ILLIQUID / PERIODIC CALL AUCTION SELL
# Automatically place a sell order for specific stocks in holdings at 9:30 AM
# with a 200ms delay. Useful for T2T / ESM Stage 2 illiquid securities.
# ─────────────────────────────────────────────────────────────────────────────

# Comma-separated list of trading symbols to auto-sell at 9:30 AM.
# Example: ILLIQUID_SELL_STOCKS=EMPOWER-BE,OTHER-BE
# Leave empty to disable.
ILLIQUID_SELL_STOCKS=EMPOWER-BE
